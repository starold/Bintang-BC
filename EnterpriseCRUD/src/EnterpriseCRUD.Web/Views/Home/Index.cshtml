@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Dashboard Overview</h1>
    <a href="#" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="bi bi-download"></i> Generate Report
    </a>
</div>

<div class="row">
    <!-- Modules Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start-primary shadow h-100 py-2" style="border-left: 0.25rem solid var(--primary) !important;">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1 small">
                            Active Modules</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.ModuleCount</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-layers fs-2 text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Points Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start-success shadow h-100 py-2" style="border-left: 0.25rem solid var(--success) !important;">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1 small">
                            Total Records</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">1,250</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-database fs-2 text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start-info shadow h-100 py-2" style="border-left: 0.25rem solid var(--info) !important;">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1 small">
                            Active Sessions</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">18</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-people fs-2 text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Errors Card -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start-warning shadow h-100 py-2" style="border-left: 0.25rem solid var(--warning) !important;">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1 small">
                            System Health</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">99.8%</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-activity fs-2 text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-white">
                <h6 class="m-0 font-weight-bold text-primary">Recent Activity</h6>
            </div>
            <div class="card-body">
                <p>Welcome to the <strong>Enterprise CRUD Engine</strong>. This system allows you to manage any database entity dynamically using metadata definitions.</p>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Pro Tip:</strong> You can add new modules without redeploying the application by using the Metadata Manager.
                </div>
                <h5>Getting Started</h5>
                <ul>
                    <li>Select a module from the sidebar to view records.</li>
                    <li>Use the "New" button to create new entries.</li>
                    <li>Global search is available at the top for quick access.</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-white">
                <h6 class="m-0 font-weight-bold text-primary">System Info</h6>
            </div>
            <div class="card-body">
                <p><strong>Environment:</strong> Development</p>
                <p><strong>Database:</strong> SQLite</p>
                <p><strong>Version:</strong> 2.5.0-alpha</p>
                <hr>
                <div class="text-center">
                    <img src="https://img.icons8.com/color/144/checked-laptop.png" alt="system-health" style="width: 100px;">
                    <p class="mt-2 text-success fw-bold">System Status: OK</p>
                </div>
            </div>
        </div>
    </div>
</div>
