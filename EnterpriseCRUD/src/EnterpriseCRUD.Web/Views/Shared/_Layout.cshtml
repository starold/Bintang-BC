<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Enterprise CRUD</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="container-fluid p-0">
        <div class="row g-0">
            <!-- Sidebar -->
            <nav id="sidebar" class="col-md-3 col-lg-2 d-md-block bg-white sidebar border-end shadow-sm vh-100 position-sticky top-0">
                <div class="sidebar-header p-3 border-bottom d-flex align-items-center gap-2">
                    <div class="bg-primary rounded p-1 text-white">
                        <i class="bi bi-layers-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Enterprise</h5>
                        <small class="text-muted">CRUD Engine</small>
                    </div>
                </div>
                
                @await Component.InvokeAsync("Sidebar")
                
                <div class="position-absolute bottom-0 w-100 p-3 border-top bg-light">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-secondary rounded-circle" style="width: 32px; height: 32px;"></div>
                        <div class="small">
                            <div class="fw-bold">Administrator</div>
                            <div class="text-muted text-truncate" style="max-width: 100px;">admin@system.com</div>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
